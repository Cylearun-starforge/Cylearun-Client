{
  "include": ["env.d.ts", "src/**/*.vue", "src/**/*.ts", "src/**/*.tsx", "types/**/*.d.ts", "../../types/**/*.d.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "compilerOptions": {
    "types": ["vite/vitest/globals"],
    "baseUrl": ".",
    "jsx": "preserve",
    "paths": {
      "#preload": ["../preload/src/index"],
      "@/*": ["../renderer/src/*"]
    },
    "lib": ["ESNext", "dom", "dom.iterable"]
  },
  "references": [
    {
      "path": "../typescript/config/tsconfig.json"
    },
    {
      "path": "@vue/tsconfig/tsconfig.web.json"
    }
  ]
}
